generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─── Enums ───────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  STAFF
  CUSTOMER
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
}

enum OrderStatus {
  PENDING_PAYMENT
  WAITING_PAYMENT_REVIEW
  PAYMENT_REJECTED
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  PROMPTPAY_QR
  COD
}

enum PaymentStatus {
  AWAITING_SLIP
  WAITING_REVIEW
  APPROVED
  REJECTED
  COD_PENDING
  COD_PAID
  CANCELLED
}

enum InventoryTransactionType {
  RESTOCK
  SALE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN_IN
  RETURN_OUT
}

enum AddressType {
  HOME
  WORK
  OTHER
}

// ─── User (unified: Admin / Staff / Customer) ────────────────────────

model User {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String?
  email        String   @unique
  phone        String?
  passwordHash String
  role         UserRole @default(CUSTOMER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  addresses        UserAddress[]
  carts            Cart[]
  orders           PurchaseOrder[]
  reviewedPayments Payment[]      @relation("PaymentReviewedBy")
  refreshTokens    RefreshToken[]

  @@index([role, isActive])
  @@index([lastName, firstName])
  @@index([phone])
  @@index([createdAt])
  @@map("users")
}

// ─── Refresh Token ───────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @db.VarChar(512)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── User Address ────────────────────────────────────────────────────

model UserAddress {
  id             String      @id @default(cuid())
  userId         String
  type           AddressType @default(HOME)
  label          String?
  recipientName  String
  recipientPhone String
  line1          String
  line2          String?
  subDistrict    String?
  district       String?
  province       String
  postalCode     String
  isDefault      Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, isDefault])
  @@map("user_addresses")
}

// ─── Category ────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("categories")
}

// ─── Brand ───────────────────────────────────────────────────────────

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  website     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("brands")
}

// ─── Product ─────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  slug        String   @unique
  name        String
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  stockQty    Int      @default(0)
  isActive    Boolean  @default(true)
  categoryId  String
  brandId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category      Category              @relation(fields: [categoryId], references: [id])
  brand         Brand                 @relation(fields: [brandId], references: [id])
  images        ProductImage[]
  attributes    ProductAttribute[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  inventoryLogs InventoryTransaction[]

  @@index([categoryId])
  @@index([brandId])
  @@index([name])
  @@index([isActive])
  @@index([categoryId, isActive])
  @@index([brandId, isActive])
  @@map("products")
}

// ─── Product Image ───────────────────────────────────────────────────

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  imageUrl  String
  altText   String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, isPrimary])
  @@unique([productId, sortOrder])
  @@map("product_images")
}

// ─── Product Attribute ───────────────────────────────────────────────

model ProductAttribute {
  id        String   @id @default(cuid())
  productId String
  name      String
  value     String   @db.Text
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@unique([productId, name])
  @@map("product_attributes")
}

// ─── Cart ────────────────────────────────────────────────────────────

model Cart {
  id        String     @id @default(cuid())
  userId    String
  status    CartStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User       @relation(fields: [userId], references: [id])
  items CartItem[]

  @@index([userId])
  @@index([userId, status])
  @@index([updatedAt])
  @@map("carts")
}

// ─── Cart Item ───────────────────────────────────────────────────────

model CartItem {
  cartId    String
  productId String
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@id([cartId, productId])
  @@index([productId])
  @@map("cart_items")
}

// ─── Purchase Order ──────────────────────────────────────────────────

model PurchaseOrder {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String
  status          OrderStatus @default(PENDING_PAYMENT)

  subTotal        Decimal @db.Decimal(10, 2)
  shippingFee     Decimal @default(0) @db.Decimal(10, 2)
  grandTotal      Decimal @db.Decimal(10, 2)

  recipientName   String
  recipientPhone  String
  shippingAddress String  @db.Text
  note            String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User        @relation(fields: [userId], references: [id])
  items   OrderItem[]
  payment Payment?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("purchase_orders")
}

// ─── Order Item ──────────────────────────────────────────────────────

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  productSku  String
  productName String
  unitPrice   Decimal  @db.Decimal(10, 2)
  quantity    Int
  lineTotal   Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  order   PurchaseOrder @relation(fields: [orderId], references: [id])
  product Product       @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([orderId, productId])
  @@map("order_items")
}

// ─── Payment ─────────────────────────────────────────────────────────

model Payment {
  id           String        @id @default(cuid())
  orderId      String        @unique
  method       PaymentMethod
  status       PaymentStatus
  amount       Decimal       @db.Decimal(10, 2)

  qrCodeUrl    String?
  paidAt       DateTime?
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?       @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order      PurchaseOrder @relation(fields: [orderId], references: [id])
  reviewedBy User?         @relation("PaymentReviewedBy", fields: [reviewedById], references: [id])
  slips      PaymentSlip[]

  @@index([method, status])
  @@index([reviewedById])
  @@index([createdAt])
  @@map("payments")
}

// ─── Payment Slip ────────────────────────────────────────────────────

model PaymentSlip {
  id         String   @id @default(cuid())
  paymentId  String
  imageUrl   String
  uploadedAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([uploadedAt])
  @@map("payment_slips")
}

// ─── Inventory Transaction ───────────────────────────────────────────

model InventoryTransaction {
  id          String                   @id @default(cuid())
  productId   String
  type        InventoryTransactionType
  quantity    Int
  referenceId String?
  note        String?                  @db.Text
  createdAt   DateTime                 @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@index([productId, createdAt])
  @@map("inventory_transactions")
}
